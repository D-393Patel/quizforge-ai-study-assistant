# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Optional backup used only after retryable Gemini failures.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
AI_FALLBACK_ENABLED=false

# Set to true to evaluate the full app without an API key.
MOCK_AI=false
PORT=3000
